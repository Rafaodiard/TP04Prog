@{
    ViewData["Title"] = "Registrarse";
}

<form method="post" action='@Url.Action("Register","Account")' id="formRegister" class="formulario">
    <h1>Registrarse</h1>

    <label>nombre</label><br />
    <input type="text" name="nombre" required />
    <label>Usuario</label><br />
    <input type="text" name="usuario" required />

    <br /><br />

    <label>Contraseña</label><br />
    <input type="password" name="password" id = "contra1" required />
    <label>Repetir contraseña</label><br />
    <input type="password" name="password2" id="contra2" required />

    <br /><br />

    <button type="submit">Ingresar</button>

    <p>¿ya tienes una cuenta?  <a href="@Url.Action("index", "Account")">iniciar sesion</a></p>

</form>
<p id="errorMessage"> </p>




@section Scripts {
    <script src="/js/Account.js"></script>
}