@{
    ViewData["Title"] = "Álbum FIFA 2026";
}

<section class="hero">

    <div class="hero-texto">
        <h1>Álbum Digital FIFA 2026</h1>

        <p>
            Coleccioná las mejores figuritas del Mundial 2026,
            abrí sobres, completá todas las selecciones y convertite
            en el mejor coleccionista.
        </p>

        <div class="hero-botones">
            <a href="@Url.Action("Register", "Home")" class="btn-principal">
                Comenzar
            </a>

            <a href="@Url.Action("Login", "Home")" class="btn-secundario">
                Iniciar sesión
            </a>
        </div>

    </div>

    <div class="hero-imagen">
        <img src="~/images/jugadores/messi.svg" alt="Messi">
    </div>

</section>

<section class="caracteristicas">

    <div class="card">

        <h2>📦 Abrí sobres</h2>

        <p>
            Conseguí nuevas figuritas todos los días y descubrí
            jugadores de las mejores selecciones.
        </p>

    </div>

    <div class="card">

        <h2>📖 Completá tu álbum</h2>

        <p>
            Pegá tus figuritas y llená todas las páginas del
            Mundial 2026.
        </p>

    </div>

    <div class="card">

        <h2>🏆 Coleccioná</h2>

        <p>
            Desbloqueá todas las selecciones y convertite en un
            verdadero coleccionista.
        </p>

    </div>

</section>

<section class="estadisticas">

    <div>
        <h2>30</h2>
        <p>Figuritas</p>
    </div>

    <div>
        <h2>6</h2>
        <p>Selecciones</p>
    </div>

    <div>
        <h2>1</h2>
        <p>Objetivo</p>
    </div>

</section>

<section class="cta">

    <h2>¿Listo para comenzar tu colección?</h2>

    <a href="@Url.Action("Register", "Home" )" class="btn-principal">
        Crear cuenta
    </a>

</section>